{
  "name": "stampcoin-platform",
  "version": "2.0.0",
  "description": "منصة للمعاملات الرقمية",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "db:init": "node database/init.js",
    "db:seed": "node database/seed.js",
    "docs": "jsdoc -c docs/jsdoc.conf.json",
    "deploy": "npm run build && wrangler deploy",
    "deploy:pages": "wrangler pages deploy public",
    "deploy:workers": "wrangler deploy",
    "build": "npm run lint && npm run test",
    "setup:cloudflare": "cd .cloudflare && chmod +x setup.sh && ./setup.sh"
  },
  "keywords": [
    "stampcoin",
    "cryptocurrency",
    "blockchain",
    "transactions",
    "digital-currency",
    "payments"
  ],
  "author": "Stampcoin Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "winston": "^3.10.0",
    "config": "^3.3.9",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.10.0",
    "validator": "^13.9.0",
    "@cloudflare/kv-asset-handler": "^0.2.0",
    "wrangler": "^3.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.46.0",
    "jsdoc": "^4.0.2",
    "@cloudflare/workers-types": "^3.0.0",
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=16.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zedanazad43/stampcoin-platform.git"
  },
  "bugs": {
    "url": "https://github.com/zedanazad43/stampcoin-platform/issues"
  },
  "homepage": "https://github.com/zedanazad43/stampcoin-platform#readme"
}