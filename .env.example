# إعدادات الخادم
PORT=3000
NODE_ENV=development
HOST=localhost

# إعدادات قاعدة البيانات
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stampcoin_platform
DB_USER=stampcoin_user
DB_PASSWORD=your_secure_password

# إعدادات API
API_SECRET=your_api_secret_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1h

# إعدادات الشبكة
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# إعدادات المعاملات
DEFAULT_CURRENCY=STAMP
MIN_TRANSACTION_AMOUNT=1
MAX_TRANSACTION_AMOUNT=1000000

# إعدادات المراقبة (Monitoring)
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_PORT=9090